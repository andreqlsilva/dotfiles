{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,

    // The Layout
    "modules-left": ["custom/launcher", "tray", "wlr/taskbar"],
    "modules-center": ["clock"],
    "modules-right": ["custom/cpu", "custom/gpu", "network", "bluetooth", "pulseaudio", "battery", "custom/power"],

    // 1. The Corner (Start Menu) -> Launches Fuzzel
    "custom/launcher": {
        "format": " ´îâ ",
        "on-click": "fuzzel",
        "tooltip": false
    },

    // 2. Taskbar (Open Windows)
    "wlr/taskbar": {
        "format": "{icon}",
        "on-click": "activate",
        "icon-size": 14,
        "tooltip-format": "{title}"
    },

    // 3. Power Button -> Locks screen
    "custom/power": {
        "format": "ÔĆ╗ ",
        "tooltip": false,
        "menu": "on-click",
	"menu-file": "$HOME/.config/waybar/power_menu.xml",
	"menu-actions": {
          "lock": "swaylock -f -c 000000",
	  "suspend": "systemctl suspend",
	  "reboot": "reboot",
	  "shutdown": "poweroff",
	  "exit": "labwc -e"
	}
    },

    // System Modules
    "custom/cpu": {
      "exec": "$HOME/.local/bin/cpuload",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "tooltip": true
    },
    "custom/gpu": {
      "exec": "$HOME/.local/bin/gpuload",
      "return-type": "json",
      "interval": 10,
      "format": "{}",
      "tooltip": true
    },
    "clock": {
      "format": "{:%a %d %b  %H:%M}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>"
    },
    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-muted": "­čöç Muted",
      "format-icons": {
        "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
      },
      "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "network": {
      "format-wifi": "´çź  {signalStrength}%",
      "format-ethernet": "­čľž Eth",
      "format-linked": "´çź  Connecting...",
      "format-disconnected": "ˇ░Ą« Offline",
      "on-click": "foot --title=wifi-tui -e impala",
      "tooltip-format": "{ifname} via {gwaddr}"
    },
    "bluetooth": {
      "format": "´Őô ",
      "format-disabled": "ˇ░é▓", // Icon for Bluetooth off
      "format-connected": "´Őô {device_battery_percentage}%",
      "tooltip-format": "{num_connections} connected",
      "tooltip-format-connected": "{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias} ({device_battery_percentage}%)",
      "on-click": "foot --title=bluetooth-tui -e bluetui"
    },
    "battery": {
      "states": { "warning": 30, "critical": 15 },
      "format": "{icon} {capacity}%",
      "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "tray": {
      "spacing": 10
    }
}

