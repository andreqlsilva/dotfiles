#!/bin/sh

# 1. If fuzzel is already open, kill it and exit
if pgrep -x "fuzzel" > /dev/null; then
    pkill -x "fuzzel"
    exit 0
fi

# 2. Define your curated list: "Display Name|Command"
# Add your notary scripts, TUIs, and browsers here.
declare -A apps=(
  [" Terminal"]="foot"
  ["󰈹 Web browser"]="chromium"
  ["󰏓 File manager"]="foot -e yazi"
  ["󰖩 Network"]="foot --title=wifi-tui -e impala"
  [" Bluetooth"]="foot --title=bluetooth-tui -e bluetui"
)

# 3. Create a searchable list that includes both Label and Command
# Format: "Label | command"
search_list=""
for label in "${!apps[@]}"; do
    search_list+="$label | ${apps[$label]}\n"
done

# 4. Launch Fuzzel
selection=$(printf "%s\n" "${!apps[@]}" | fuzzel --dmenu --prompt="Run: ")

# 5. If selection is empty (user hit Escape), exit
if [ -z "$selection" ]; then
    exit 0
fi

# 6. Logic: Extract the command
if [[ "$selection" == *" | "* ]]; then
    # If the user picked a curated item, grab the part after the "|"
    cmd=$(echo "$selection" | awk -F ' | ' '{print $NF}')
else
    # If the user typed a raw command that wasn't in the list
    cmd="$selection"
fi

# 7. Execute
eval "$cmd &"
