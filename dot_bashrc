#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

eval $(keychain --eval --quiet --noask id_ed25519)
#source /usr/share/nvm/init-nvm.sh

set -o vi
bind -m vi-insert "\C-l":clear-screen
#bind -m vi-insert "\C-a":beginning-of-line
#bind -m vi-insert "\C-e":end-of-line

export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'
export EDITOR='nvim'
export VISUAL='nvim'

export HISTSIZE=100000

alias tree='tree --gitignore'
alias ls='ls --color=auto'
alias grep='grep --color'

function __ps1_gitbranch {
  if [[ -z "$(git branch --show-current 2>/dev/null)" ]]; then
    PS1_CMD=""
  else
    PS1_CMD=" -> $(git branch --show-current 2>/dev/null)"
  fi
}

PROMPT_COMMAND='__ps1_gitbranch'

PS1='\u@\h \[\e[94m\e[1m\][\W\[\e[93m\]${PS1_CMD}\[\e[94m\]] \[\e[0m\]\$ '

alias less='less -Qr'
alias man='man -P "less -Qr"'

alias ..='cd ..'

alias pacman='sudo pacman'
alias update='yay -Syu'
alias mount='sudo mount'
alias umount='sudo umount'
alias service='sudo systemctl'
alias uservice='systemctl --user'
alias vim='nvim'

function chezconf() {
  nvim "$1" && chezmoi add "$1" 2>/dev/null
}

function wallpaper() {
  hyprctl hyprpaper preload "$1"
  hyprctl hyprpaper wallpaper ,"$1"

}

alias chezstat='cd $HOME/.local/share/chezmoi && git status; cd $HOME'
alias cfbash='chezconf $HOME/.bashrc; source $HOME/.bashrc'
alias cfkit='chezconf $HOME/.config/kitty/kitty.conf'
alias cfhyp='chezconf $HOME/.config/hypr/hyprland.conf'
alias cfbar='chezconf $HOME/.config/waybar/config.jsonc && rebar'
alias rebar='pkill waybar; hyprctl dispatch exec waybar'
alias cfpaper='chezconf $HOME/.config/hypr/hyprpaper.conf'
alias cflock='chezconf $HOME/.config/hypr/hyprlock.conf'
alias cfidle='chezconf $HOME/.config/hypr/hypridle.conf'
alias cdvim='cd $HOME/.config/nvim'
alias retail='sudo systemctl restart tailscaled'
alias tailstat='systemctl status tailscaled'

export WDIR="$HOME/projects/clone-tabnews"
export TDIR="$HOME/projects/doimaker"
alias wd="cd $WDIR"
alias td="cd $TDIR"

function compvid() {
    ffmpeg -i "$1" -c:v libx265 -crf 28 -c:a aac -strict experimental -b:a 96k "$2"
}

